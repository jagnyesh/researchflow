# ResearchFlow Environment Configuration

# Required: Anthropic API Key for LLM features (used for critical medical tasks)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Secondary LLM Provider for non-critical tasks (calendar, delivery)
# Options: openai, ollama, anthropic (default: anthropic)
SECONDARY_LLM_PROVIDER=anthropic

# Optional: OpenAI API Key (only needed if SECONDARY_LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Ollama Base URL (only needed if SECONDARY_LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Default model for secondary provider
# Examples: gpt-4o, gpt-4-turbo (OpenAI) | llama3, mistral (Ollama)
SECONDARY_LLM_MODEL=

# Optional: Enable automatic fallback to Claude if secondary provider fails
ENABLE_LLM_FALLBACK=true

# Optional: Database URL (defaults to SQLite if not set)
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname
# Docker setup: postgresql+asyncpg://postgres:postgres@localhost:5432/fhir_db

# Optional: FHIR Server URL (for SQL-on-FHIR operations)
FHIR_SERVER_URL=http://localhost:8081/fhir
# Docker internal: http://hapi-fhir:8080/fhir

# Optional: JWT Secret for A2A authentication
A2A_JWT_SECRET=devsecret

# Optional: Data Delivery Storage Path (defaults to /data/deliveries)
# Absolute path where delivered research data files are stored
DATA_DELIVERY_PATH=/data/deliveries

# Optional: Maximum download size in MB (default: 500)
MAX_DOWNLOAD_SIZE_MB=500

# ============================================================================
# LANGSMITH OBSERVABILITY (Sprint 5)
# ============================================================================
# Enable LangSmith tracing for workflow observability
# Get API key from: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=<your-langsmith-api-key>
LANGCHAIN_PROJECT=researchflow-production

# Optional: Additional LangSmith configuration
# LANGSMITH_TAGS=production,langgraph,research
# LANGCHAIN_HUB_API_URL=https://api.hub.langchain.com

# ============================================================================
# REDIS SPEED LAYER (Sprint 5.5)
# ============================================================================
# Redis URL for Lambda architecture speed layer
# Docker: redis://redis:6379/0
# Local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Enable/disable speed layer queries (set to false to disable Redis)
USE_SPEED_LAYER=true

# ============================================================================
# AUDIT PIPELINE (Sprint 6.1 Phase 2.2)
# ============================================================================
# Isolated Redis instance for the HIPAA audit pipeline. Runs on a separate
# port (6380 host / 6379 container) with `noeviction` policy so writes fail
# loudly when full instead of silently dropping queued audit events.
# Docker: redis://redis-audit:6379/0
# Local:  redis://localhost:6380/0
REDIS_AUDIT_URL=redis://localhost:6380/0

# ============================================================================
# TLS ENFORCEMENT (Sprint 6.1 Phase 3a)
# ============================================================================
# Strict equality, case-sensitive. Valid values: development | staging | production.
# Only "production" (exact match) installs the HTTPS redirect + HSTS middleware
# and adds --proxy-headers to uvicorn. Typos fail-safe to dev behavior.
ENVIRONMENT=development

# Trust X-Forwarded-Proto from these source IPs. Default "*" assumes the container
# runs on a private network behind a TLS-terminating proxy (LB/ingress) — only
# the proxy can reach the container directly. If the container is internet-reachable,
# tighten to a specific CIDR like "10.0.0.0/8".
FORWARDED_ALLOW_IPS=*

# HSTS max-age in seconds. Default 31536000 (1 year) is Chrome's preload-list
# minimum and the institutional-defensible floor. Override only for incident
# response (e.g., emit short-lived HSTS during HTTPS outage so caches expire fast).
HSTS_MAX_AGE=31536000

# CSV of valid hostnames for the production deployment. Validates the Host header
# via Starlette's TrustedHostMiddleware to prevent open-redirect attacks where an
# attacker's forged Host header would otherwise steer the 308 redirect to evil.com.
# Default "*" disables validation (with a startup warning); set to your real
# domain(s) in production. Supports subdomain wildcards: "*.researchflow.example".
ALLOWED_HOSTS=*

# ============================================================================
# ENCRYPTION-AT-REST (Sprint 6.1 Phase 3b)
# ============================================================================
# Active Fernet key for column-level encryption of free-form PHI columns
# (ResearchRequest.initial_request, ResearchRequest.structured_requirements,
# RequirementsData.inclusion_criteria, RequirementsData.exclusion_criteria,
# FeasibilityReport.phenotype_sql).
#
# REQUIRED in production — app refuses to start (RuntimeError in lifespan) if
# unset or malformed. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Rotation procedure: see docs/HIPAA_POSTURE.md → Phase 3b → Key rotation runbook.
# DO NOT commit a real production key to source control or .env files in git.
ENCRYPTION_KEY_PRIMARY=

# ============================================================================
# ORCHESTRATOR (LangGraph is the production default since Sprint 7.2)
# ============================================================================
# Sprint 7.2 (2026-05-17) retired the legacy custom A2A FSM in favor of the
# LangGraph declarative orchestrator. The flag below remains for backwards
# compatibility with deployments that haven't yet migrated; it will be
# removed entirely in Sprint 7.2 Phase 5 (dispatcher simplification).
# Leave at the default unless you have a specific reason to revert.
USE_LANGGRAPH_WORKFLOW=true

# Gradual rollout: Percentage of NEW requests to route to LangGraph (0-100).
# Phase 1 parity verification (2026-05-17) confirmed LangGraph behaves
# equivalently to A2A on every Sprint-7.2-relevant axis. Default is now 100.
# This flag is also slated for removal in Phase 5.
LANGGRAPH_ROLLOUT_PCT=100

# Sprint 6.7 #92: scoped read-only execution identity for LLM-synthesized
# exploratory SQL. When USE_LLM_SQL_SYNTHESIS is on, the synthesis path executes
# through this connection (the `rf_readonly` role — SELECT on sqlonfhir views
# only, no writes/DDL, no raw hfj_resource PHI access). Falls back to HAPI_DB_URL
# when unset, so dev/test without the role still work. Created on a fresh
# docker volume by config/rf_readonly_role.sql; OVERRIDE the dev-default
# password below in any real deployment.
EXPLORATORY_DB_URL=postgresql://rf_readonly:rf_readonly@localhost:5433/hapi  # pragma: allowlist secret

# Sprint 6.7 #99: exploratory portal LLM SQL synthesis. When true, an NL cohort
# question is turned into SELECT-only SQL by a single LLM call, passed through the
# default-deny validator (ADR 0028), and executed via EXPLORATORY_DB_URL above.
# When false, the legacy JoinQueryBuilder/QueryInterpreter path runs.
# Flipped to true 2026-07-12 after the pre-committed gate cleared: exec accuracy
# 100% (Sonnet 4.6) / 91.3% (Opus 4.8) — both ≥90%; 0/8 adversarial escapes on
# both; honest-failure invariant green. Model rule selected Sonnet (gap 8.7pts>5
# → higher accuracy). Evidence: logs/sprint_6_7_gate.jsonl (scripts/sprint_6_7_gate.py).
# REQUIRES EXPLORATORY_DB_URL set (the fail-closed guard hard-fails in production
# otherwise). Model is SYNTHESIS_MODEL in app/services/sql_synthesis.py.
USE_LLM_SQL_SYNTHESIS=true
